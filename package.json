{
  "name": "street-tank",
  "version": "1.0.0",
  "description": "Browser-based multiplayer tank combat on Google 3D Tiles",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview",
    "fetch-osm": "node server/tools/fetch-osm-footprints.js"
  },
  "keywords": [
    "tank",
    "game",
    "cesium",
    "3d",
    "multiplayer"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cesium": "^1.138.0",
    "express": "^5.2.1",
    "nanoid": "^5.1.6",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^7.3.1",
    "vite-plugin-cesium": "^1.2.23",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2"
  }
}
